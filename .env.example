# Pulse Protocol MVP - Environment Variables

# ── Database ──
# Port 5432 matches docker-compose default mapping
DATABASE_URL=postgres://pulse:pulse_dev@localhost:5432/pulse_protocol

# ── Server ──
HOST=127.0.0.1
PORT=8080

# ── Stellar / Soroban ──
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Oracle (generates via: stellar keys generate pulse-oracle --network testnet) ──
ORACLE_SECRET_KEY=S...

# ── Contract IDs (set after running scripts/deploy_testnet.sh) ──
VAULT_CONTRACT_ID=
PROOF_OF_LIFE_CONTRACT_ID=
BENEFICIARY_CONTRACT_ID=

# ── Trustless Work (backend-orquesta mode) ──
TW_FACTORY_CONTRACT_ID=
